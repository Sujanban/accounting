    {
      "name": "Fiscal Years",
      "item": [
        { "name": "List Fiscal Years", "request": { "method": "GET", "url": "{{baseUrl}}/api/fiscal-years" } },
        { "name": "Create Fiscal Year", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{ \"name\": \"2083/84\", \"startDateBS\": \"2083-04-01\", \"endDateBS\": \"2084-03-31\", \"startDateAD\": \"2026-07-16\", \"endDateAD\": \"2027-07-15\" }" }, "url": "{{baseUrl}}/api/fiscal-years" } },

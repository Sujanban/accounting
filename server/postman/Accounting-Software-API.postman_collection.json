        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Acme Accounting Pvt Ltd\",\n  \"panNumber\": \"123456789\",\n  \"vatRegistered\": true,\n  \"vatNumber\": \"VAT-123456\",\n  \"phone\": \"+9779800000000\",\n  \"email\": \"info@acme.com\",\n  \"address\": \"Kathmandu, Nepal\",\n  \"logo\": \"https://cdn.example.com/logo.png\",\n  \"fiscalYear\": {\n    \"name\": \"2082/83\",\n    \"startDateBS\": \"2082-04-01\",\n    \"endDateBS\": \"2083-03-31\"\n  },\n  \"businessType\": \"Retail Shop\"\n}"

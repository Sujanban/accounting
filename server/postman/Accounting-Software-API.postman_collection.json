{
  "info": {
    "_postman_id": "4f67f6f1-5b34-47b8-9bf3-c1b6176b7d90",
    "name": "Accounting Software API",
    "description": "Current API routes. Run Register or Login first. Set companyId and fiscalYearId after creating a company; authenticated requests inherit these values.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001" },
    { "key": "accessToken", "value": "" },
    { "key": "companyId", "value": "" },
    { "key": "fiscalYearId", "value": "" },
    { "key": "accountGroupId", "value": "" },
    { "key": "ledgerId", "value": "" },
    { "key": "voucherSequenceId", "value": "" },
    { "key": "contactId", "value": "" },
    { "key": "unitId", "value": "" },
    { "key": "branchId", "value": "" },
    { "key": "warehouseId", "value": "" },
    { "key": "transactionId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!(pm.request.auth && pm.request.auth.type === 'noauth')) {",
          "  pm.request.headers.upsert({ key: 'x-company-id', value: pm.collectionVariables.get('companyId') || '' });",
          "  pm.request.headers.upsert({ key: 'x-fiscal-year-id', value: pm.collectionVariables.get('fiscalYearId') || '' });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "System & Documentation",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "System Health",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": "{{baseUrl}}/api/system/health"
          }
        },
        {
          "name": "System Metrics",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/system/metrics"
          }
        },
        {
          "name": "OpenAPI JSON",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": "{{baseUrl}}/api/docs/openapi.json"
          }
        },
        {
          "name": "Swagger UI",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": "{{baseUrl}}/api/docs/"
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sujan Ban\",\n  \"email\": \"sujan@example.com\",\n  \"password\": \"StrongPass123!\",\n  \"confirmPassword\": \"StrongPass123!\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) { pm.collectionVariables.set('accessToken', pm.response.json().data.accessToken); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"sujan@example.com\",\n  \"password\": \"StrongPass123!\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "url": "{{baseUrl}}/api/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "auth": { "type": "noauth" },
            "url": "{{baseUrl}}/api/auth/logout"
          }
        },
        {
          "name": "Current Session",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/auth/me" }
        }
      ]
    },
    {
      "name": "Company & Settings",
      "item": [
        {
          "name": "Create Company",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Accounting Pvt Ltd\",\n  \"panNumber\": \"123456789\",\n  \"vatRegistered\": true,\n  \"vatNumber\": \"123456789\",\n  \"fiscalYear\": { \"name\": \"2082/83\", \"startDateBS\": \"2082-04-01\", \"endDateBS\": \"2083-03-31\", \"startDateAD\": \"2025-07-17\", \"endDateAD\": \"2026-07-16\" }\n}"
            },
            "url": "{{baseUrl}}/api/companies"
          }
        },
        {
          "name": "Create Settings",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"businessType\": \"RETAIL\",\n  \"currency\": \"NPR\",\n  \"dateFormat\": \"BS\",\n  \"timezone\": \"Asia/Kathmandu\",\n  \"decimalPlaces\": 2\n}"
            },
            "url": "{{baseUrl}}/api/settings"
          }
        },
        {
          "name": "Get Active Company",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/companies/{{companyId}}" }
        },
        {
          "name": "Update Active Company",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"name\": \"Acme Accounting Pvt Ltd\", \"phone\": \"+9779800000000\", \"address\": \"Kathmandu, Nepal\" }" },
            "url": "{{baseUrl}}/api/companies/{{companyId}}"
          }
        },
        {
          "name": "Get General Settings",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/settings" }
        },
        {
          "name": "Update General Settings",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"businessType\": \"RETAIL\", \"currency\": \"NPR\", \"currencySymbol\": \"Rs.\", \"dateFormat\": \"BS\", \"decimalPlaces\": 2, \"allowNegativeStock\": false }" },
            "url": "{{baseUrl}}/api/settings"
          }

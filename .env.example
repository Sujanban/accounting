# Single-service runtime
NODE_ENV=development
PORT=5001

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/accounting_software

# Authentication — use long, unique secrets in every environment.
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# API protection
REQUEST_BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Optional: only needed when a separate frontend origin calls this API.
# CLIENT_ORIGIN=http://localhost:3000
